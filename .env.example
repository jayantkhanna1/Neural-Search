# --- Required -------------------------------------------------------------
# Anthropic API key used for query expansion, relevance filtering,
# summarization and RAG chat (Haiku model).
ANTHROPIC_API_KEY=

# --- Django ----------------------------------------------------------------
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=*
# CSRF_TRUSTED_ORIGINS=https://your-domain.example

# --- Redis / Celery ---------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# --- Database (optional; SQLite is used when DB_NAME is unset) --------------
# DB_NAME=
# DB_USER=
# DB_PASSWORD=
# DB_HOST=localhost
# DB_PORT=5432

# --- Search providers (optional but recommended) -----------------------------
# Reliable search APIs; without keys the app falls back to DuckDuckGo/Google scraping.
# TAVILY_API_KEY=
# BRAVE_API_KEY=

# --- Hybrid retrieval (optional) ---------------------------------------------
# When set, chunks get Voyage AI embeddings and retrieval fuses BM25 + semantic.
# VOYAGE_API_KEY=
# VOYAGE_MODEL=voyage-3.5-lite

# --- Research pipeline tuning (all optional) ---------------------------------
# ANTHROPIC_MODEL=claude-haiku-4-5
# RESEARCH_EXPANDED_QUERIES=5
# RESEARCH_MAX_ROUNDS=2                # iterative deep-research rounds
# RESEARCH_GAP_QUERIES=3               # follow-up queries per extra round
# RESEARCH_TASK_TOKEN_BUDGET=400000    # LLM token cap per research task
# RESEARCH_RESULTS_PER_QUERY=8
# RESEARCH_MAX_URLS_PER_TASK=30
# RESEARCH_FETCH_CONCURRENCY=8
# RESEARCH_RELEVANCE_THRESHOLD=0.55
# RESEARCH_PER_DOMAIN_DELAY=2.0
# RESEARCH_RESPECT_ROBOTS=true
# RESEARCH_CONTEXTUAL_CHUNKS=true      # situating line per chunk (contextual retrieval)
# RESEARCH_USE_BATCH_SUMMARIES=false   # Message Batches API for summaries (50% cost)
# RESEARCH_ENABLE_BROWSER=false        # Playwright fallback for JS-heavy pages
